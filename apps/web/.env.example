# URL of the StandoffDuel NestJS gateway
NEXT_PUBLIC_SOCKET_URL=http://localhost:3002

# Public origin of the web app - used for canonical URLs and OG image preview
# links. On Vercel this is auto-derived from VERCEL_PROJECT_PRODUCTION_URL, so
# you only need to set it for custom domains / non-Vercel hosts.
# NEXT_PUBLIC_SITE_URL=https://standoffduel.example

# TURN relay (optional but strongly recommended for production). STUN alone
# fails for players behind symmetric NAT / CGNAT / mobile carriers. Grab free
# credentials from metered.ca or Twilio NTS, or run your own coturn.
# Comma-separate multiple URLs (udp + tcp/tls fallbacks).
# NEXT_PUBLIC_TURN_URLS=turn:turn.example.com:3478,turns:turn.example.com:5349
# NEXT_PUBLIC_TURN_USERNAME=your-turn-username
# NEXT_PUBLIC_TURN_CREDENTIAL=your-turn-credential
