# Port the API + Socket.io server listens on
PORT=3002

# Comma-separated allowed browser origins for CORS.
# Leave unset in local dev to reflect any origin; set explicitly in production.
WEB_ORIGIN=http://localhost:3000

# Redis connection for durable, shareable duel-result permalinks (/r/<id>).
# Any redis(s):// URL works - Railway Redis injects this automatically, or use
# an Upstash URL. Leave unset to fall back to in-memory (fine for a single
# long-lived instance; results reset on redeploy).
# REDIS_URL=redis://default:password@host:6379
